# JustDoIt self-hosting environment. Copy to .env and fill in.
# See SELF_HOSTING.md for how each value is produced.

# ── Frontend (web) ────────────────────────────────────────────────────────────
WEB_PORT=3000
# Public Supabase URL the browser uses. With the shared Docker network this can
# be an internal name, but the browser needs a URL it can reach — usually your
# public Supabase URL (e.g. https://supabase.example.com).
NEXT_PUBLIC_SUPABASE_URL=https://supabase.example.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Edge Functions / jobs (set as Supabase function secrets + Trigger env) ─────
# Email: leave RESEND_API_KEY empty and set SMTP_* for a fully self-hosted,
# no-cloud email path. If SMTP_HOST is set it takes precedence over Resend.
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
FROM_EMAIL=noreply@example.com
RESEND_API_KEY=

# App URL used in email links.
APP_URL=https://app.example.com

# Background jobs (self-hosted Trigger.dev).
TRIGGER_SECRET_KEY=
# Point auth-hook + the CLI at your self-hosted Trigger.dev instead of the cloud.
TRIGGER_API_URL=https://trigger.example.com

# AI (optional). Leave empty to disable AI features.
ANTHROPIC_API_KEY=
