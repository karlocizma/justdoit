# ── Supabase (local — run `supabase start` to get these) ──────────────────────
SUPABASE_URL=http://127.0.0.1:14321
SUPABASE_ANON_KEY=<Publishable key from `supabase start` output>
SUPABASE_SERVICE_ROLE_KEY=<Secret key from `supabase start` — never expose to client>

# ── OAuth providers ───────────────────────────────────────────────────────────
# GitHub — create OAuth App at github.com/settings/developers
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=<your GitHub client ID>
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=<your GitHub client secret>

# Google — create credentials at console.cloud.google.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=<your Google client ID>
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=<your Google client secret>

# ── Auth hook ─────────────────────────────────────────────────────────────────
HOOK_SECRET=<random secret shared between Supabase Auth and the auth-hook Edge Function>

# ── Trigger.dev ───────────────────────────────────────────────────────────────
TRIGGER_SECRET_KEY=<from trigger.dev dashboard>

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=<from resend.com dashboard>
FROM_EMAIL=noreply@yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
